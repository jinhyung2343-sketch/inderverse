# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Inderverse SMTP via Resend or another verified sender
# Used by the app server for branded signup, password reset, and welcome emails.
INDERVERSE_SMTP_HOST=smtp.resend.com
INDERVERSE_SMTP_USER=resend
INDERVERSE_SMTP_PASS=your-smtp-password-or-api-key
INDERVERSE_SMTP_FROM_EMAIL=no-reply@your-verified-domain.com
INDERVERSE_SMTP_FROM_NAME=Inderverse

# Supabase Storage
SUPABASE_STORAGE_BUCKET=artwork-assets

# Age verification
PASS_VERIFY_START_URL=https://pass-provider.example.com/start
PHONE_VERIFY_START_URL=https://phone-provider.example.com/start
AGE_VERIFICATION_STATE_SECRET=replace-with-a-long-random-string
AGE_VERIFICATION_PROVIDER_SECRET=replace-with-a-provider-callback-secret
ENABLE_DEV_MANUAL_AGE_VERIFICATION=false

# Development-only coin charge switch
ENABLE_DEV_COIN_CHARGE=false
ENABLE_DEV_SUBSCRIPTION_CHECKOUT=false

# Internal cron/job authorization.
# Vercel Cron sends this as: Authorization: Bearer ${CRON_SECRET}
CRON_SECRET=replace-with-a-long-random-string
STORAGE_CLEANUP_SECRET=
WEBTOON_IMAGE_PROCESSING_SECRET=
INTERNAL_JOB_SECRET=

# Revenue security
BANK_INFO_ENCRYPTION_SECRET=replace-with-a-long-random-string

# PWA Push Notifications (VAPID)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
